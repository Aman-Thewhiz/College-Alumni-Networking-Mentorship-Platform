# Backend
PORT=5000
MONGO_URI=mongodb+srv://ATLAS_USERNAME:ATLAS_PASSWORD@ATLAS_CLUSTER_URL/alumniconnect?retryWrites=true&w=majority
# Use 4 to force IPv4 if your network has IPv6/TLS handshake issues with Atlas.
MONGO_DNS_FAMILY=4
MONGO_CONNECT_RETRIES=8
MONGO_CONNECT_RETRY_DELAY_MS=3000
JWT_SECRET=replace-with-a-secure-secret
FRONTEND_URL=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
