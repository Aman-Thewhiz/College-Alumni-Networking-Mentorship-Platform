PORT=5000
# Use your Atlas SRV string. URL-encode the password if it contains special characters.
MONGO_URI=mongodb+srv://ATLAS_USERNAME:ATLAS_PASSWORD@ATLAS_CLUSTER_URL/alumniconnect?retryWrites=true&w=majority
# Use 4 to force IPv4 if your network has IPv6/TLS handshake issues with Atlas.
MONGO_DNS_FAMILY=4
# Retries help with transient Atlas TLS/network handshakes on some networks.
MONGO_CONNECT_RETRIES=8
MONGO_CONNECT_RETRY_DELAY_MS=3000
JWT_SECRET=replace_with_a_secure_jwt_secret
FRONTEND_URL=http://localhost:5173
